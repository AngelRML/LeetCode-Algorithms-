/*
You are given two non-empty linked lists representing two non-negative integers. The digits are stored in reverse order, and each of their nodes contains a single digit. Add the two numbers and return the sum as a linked list.
You may assume the two numbers do not contain any leading zero, except the number 0 itself.

Example 1:
Input: l1 = [2,4,3], l2 = [5,6,4]
Output: [7,0,8]
Explanation: 342 + 465 = 807
*/

/**
 * Definition for singly-linked list.
 * function ListNode(val, next) {
 *     this.val = (val===undefined ? 0 : val)
 *     this.next = (next===undefined ? null : next)
 * }
 */
/**
 * @param {ListNode} l1
 * @param {ListNode} l2
 * @return {ListNode}
 */
var addTwoNumbers = function(l1, l2) {
    let lnList  = new ListNode(0);   // Lista donde se guardara el resultado
    let nActual = lnList;   // Nodo actual de la lista resultado
    let nAux    = 0; // Variable auxiliar para sumas mayores que 10

    while(l1 !== null || l2 !== null || nAux !== 0){
        // Guarda el valor del nodo actual de las listas
        let nVal1 = l1 ? l1.val : 0;    
        let nVal2 = l2 ? l2.val : 0;

        let nSuma = nVal1 + nVal2 + nAux;   // Se realiza la suma de ambos nodos y el auxiliar

        nAux = (nSuma >= 10) ? 1 : 0;   // Si el resultado de la suma es mayor o igual a 10, llevamos 1 en el auxiliar, si no pues no

        let nValorNodo = (nSuma >= 10) ? (nSuma - 10) : nSuma;  // Si el resultado de la suma es mayor o igual a 10 obtenemos el numero de la derecha restando 10

        nActual.next = new ListNode(nValorNodo);    // Se agrega el valor en un nuevo nodo de la lista resultado
        nActual = nActual.next; // Accedemos al siguiente valor de la lista resultado (null)

        // Accedemos al siguiente valor de los nodos de entrada
        if (l1){
            l1 = l1.next;
        }
        if (l2){
            l2 = l2.next;
        }
    }

    return lnList.next;
};
